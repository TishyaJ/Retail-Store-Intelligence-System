# Environment Variables — copy this file to .env and fill in secrets
# cp .env.example .env

# === PostgreSQL / TimescaleDB ===
POSTGRES_USER=purplle
POSTGRES_PASSWORD=purplle_secret
POSTGRES_DB=retail_intelligence
DATABASE_URL=postgresql+asyncpg://purplle:purplle_secret@database:5432/retail_intelligence

# === API Server ===
API_SERVER_URL=http://api-server:8000

# === Vision Pipeline ===
USE_ONNX_CPU=true
PIPELINE_BATCH_SIZE=50
PIPELINE_FLUSH_INTERVAL=2

# === Store Configuration ===
STORE1_ID=ST1076
STORE2_ID=ST1008

# === Clip Start UTC Timestamps (MUST match POS data dates for /funnel correlation) ===
# Store 1 date anchored to sample_events.jsonl timestamps (2026-03-08)
STORE1_CLIP_START_UTC=2026-03-08T12:00:00Z
# Store 2 date anchored to POS_transactions.csv date (2026-04-10)
STORE2_CLIP_START_UTC=2026-04-10T12:00:00Z

# === Logging ===
LOG_LEVEL=INFO
